{
  "name": "vco-okpos-agent",
  "version": "1.0.1",
  "description": "VCO OKPOS Agent for FAI",
  "author": "FAI",
  "scripts": {
    "transpile": "rimraf \"dist\" && tsc && xcopy \"src\\dll\" \"dist\\src\\dll\" /Y /i && xcopy \"src\\assets\" \"dist\\assets\" /Y /i && xcopy \"src\\package\" \"dist\\package\" /Y /i",
    "start": "yarn transpile && echo 1234 > config.txt && electron .",
    "build": "yarn transpile && rimraf \"FAI VCO OKPOS Agent\" && electron-builder && echo 1234 > \"FAI VCO OKPOS Agent/config.txt\""
  },
  "main": "dist/main.js",
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "axios": "^1.9.0",
    "body-parser": "^2.2.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "iconv-lite": "^0.6.3",
    "koffi": "^2.9.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/express": "^5.0.1",
    "electron": "33.0.2",
    "electron-builder": "^25",
    "electron-rebuild": "^3.2.9",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "ai.fainders.vcookposagent",
    "productName": "FAI VCO OKPOS Agent",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "FAI VCO OKPOS Agent"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/koffi/build/koffi",
      "dist/src/dll/*.dll",
      "dist/src/dllProcess"
    ],
    "extraResources": [
      {
        "from": "src/assets",
        "to": "assets"
      },
      {
        "from": "src/package",
        "to": "package"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "ia32"
          ]
        }
      ],
      "icon": "src/assets/app-icon.png"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "electron": ">=33.0.0"
  }
}
