# [deploy key] S3 업로드용 — publish:dev / publish:prd 실행 시 필요 (CI/CD secrets에 보관)
# 필요 권한: vco-installer/*/vco-okpos-agent/* 에 대한 PutObject, GetObject, DeleteObject, ListBucket
AWS_ACCESS_KEY_ID=your_deploy_key_id_here
AWS_SECRET_ACCESS_KEY=your_deploy_secret_here

# [updater key] 앱 바이너리에 포함되는 read-only 키 — 빌드 타임에 extraMetadata로 번들에 포함됨
# 필요 권한: vco-installer/*/vco-okpos-agent/* 에 대한 GetObject, ListBucket only
UPDATER_AWS_ACCESS_KEY_ID=your_updater_key_id_here
UPDATER_AWS_SECRET_ACCESS_KEY=your_updater_secret_here
